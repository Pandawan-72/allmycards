rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Document trial_start lié au compte (uid). Chaque utilisateur :
    // - peut lire son propre document
    // - peut le CRÉER une seule fois (avec trial_start)
    // - ne peut JAMAIS modifier ni supprimer trial_start une fois écrit
    //   (empêche de réinitialiser le trial en désinstallant/réinstallant l'app)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.trial_start is timestamp;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.trial_start == resource.data.trial_start;

      allow delete: if false;
    }
  }
}
